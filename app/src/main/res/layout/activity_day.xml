<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="@dimen/activity_vertical_margin">

    <TextView
        android:id="@+id/title"
        style="@style/TextAppearance.Sphinx.DialogWindowTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:gravity="center"
        android:text="@string/title_is_root_veg"
        android:textColor="@color/colorTitles"
        android:layout_margin="@dimen/activity_vertical_margin"
        android:textSize="20sp" />

    <ImageView
        android:id="@+id/moonView"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_toStartOf="@id/title"/>

    <View
        android:id="@+id/divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_below="@+id/moonView"
        android:layout_marginStart="@dimen/fragment_divider_horizontal_margin"
        android:layout_marginTop="@dimen/fragment_divider_top_margin"
        android:layout_marginEnd="@dimen/fragment_divider_horizontal_margin"
        android:layout_marginBottom="@dimen/fragment_divider_bottom_margin"
        android:background="@color/colorTitleDivider" />


    <LinearLayout
        android:layout_below="@id/divider"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:orientation="vertical" >
        <ListView
            android:id="@+id/listview"
            android:layout_width="fill_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:stackFromBottom="false" />
    </LinearLayout>

</RelativeLayout>